# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ───────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# Optional local ports for the dashboard and worker health server
UI_PORT=8000
AGENT_PORT=8081

# ── LLM Selection ────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
VOICE_MODE=pipeline
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_VOICE=Puck
GEMINI_LIVE_TEMPERATURE=0.8
GEMINI_LIVE_LANGUAGE=
GEMINI_LIVE_PREFLIGHT_ENABLED=false
GEMINI_LIVE_PREFLIGHT_TIMEOUT=6
GEMINI_LIVE_FALLBACK_TO_PIPELINE=false
GEMINI_LIVE_CONNECT_TIMEOUT=20
GEMINI_LIVE_CONNECT_RETRIES=2
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
LANG_PRESET=multilingual

X_AI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_TTS_USE_SPEECH_TAGS=true
XAI_TTS_STYLE_PRESET=spirited
GOOGLE_API_KEY=

# ── Groq (LLM) ──────────────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter (optional LLM provider) ──────────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_APP_NAME=RapidX Voice Agent
OPENROUTER_SITE_URL=https://yourdomain.com

# ── Sarvam AI (STT + LLM option) ────────────────────────────────────────────
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_TTS_MODEL=bulbul:v3
TTS_VOICE=kavya

# ── Cartesia (TTS provider) ─────────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_TTS_MODEL=sonic-3
CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02
TTS_PROVIDER=cartesia

# ── Supabase (Database) ─────────────────────────────────────────────────────
# Get from: https://app.supabase.com/ → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Supabase S3 (Call Recordings) ───────────────────────────────────────────
# Get from: Supabase Dashboard → Storage → Settings → S3 Access → Generate key
# Bucket: create a private bucket named 'call-recordings' in Storage
SUPABASE_S3_ACCESS_KEY=your_supabase_s3_access_key_id
SUPABASE_S3_SECRET_KEY=your_supabase_s3_secret_access_key
SUPABASE_S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1

# ── Telegram Notifications ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your Chat ID
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── SIP / VoBiz (optional) ──────────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx

# ── Call Transfer ────────────────────────────────────────────────────────────
# Phone number to transfer calls to (human agent fallback)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Optional providers and integrations ──────────────────────────────────────
SENTRY_DSN=
N8N_WEBHOOK_URL=

# WhatsApp via Baileys QR sidecar
WHATSAPP_PROVIDER=baileys
WHATSAPP_ENABLED=true
WHATSAPP_SERVICE_URL=http://127.0.0.1:3010
WHATSAPP_SESSION_NAME=primary
WHATSAPP_WEBHOOK_SECRET=replace_with_shared_secret
WHATSAPP_AUTH_DIR=./data/whatsapp-auth/primary
WHATSAPP_WEBHOOK_URL=http://127.0.0.1:8000/api/whatsapp/events

# WhatsApp automation defaults
BOOKING_REMINDER_OFFSETS_HOURS=24,2
NO_BOOKING_FOLLOWUP_OFFSETS_HOURS=2,24
FOLLOWUP_CALL_NEXT_DAY_HOUR_IST=11
AUTOMATION_BUSINESS_HOURS_ONLY=true

# Knowledge base + Lead RRat CRM
KB_ENABLED=true
KB_BACKEND=local_faiss
KB_DATA_DIR=data/kb
KB_TOP_K=4
KB_INVENTORY_TOP_K=3
KB_SIMILARITY_THRESHOLD=0.18
KB_CONTEXT_CHAR_BUDGET=2800
KB_LIVE_TIMEOUT_MS=150
KB_LIVE_CONTEXT_CHAR_BUDGET=900
KB_CACHE_TTL_SECONDS=45
KB_CHUNK_SIZE=400
KB_CHUNK_OVERLAP=60
KB_WORKER_POLL_SECONDS=20
KB_EMBEDDING_PROVIDER=local
KB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
KB_EMBEDDING_FALLBACK_PROVIDER=gemini
KB_EMBEDDING_FALLBACK_MODEL=gemini-embedding-001
KB_INDEX_KIND=flat_ip
KB_RERANK_ENABLED=false
LEADRAT_ENABLED=false
LEADRAT_TENANT=
LEADRAT_API_KEY=
LEADRAT_SECRET_KEY=
LEADRAT_SYNC_INTERVAL_MINUTES=5
LEADRAT_BASE_URL=https://connect.leadrat.com

# Optional Twilio fallback for WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
